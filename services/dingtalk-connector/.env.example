# 钉钉开发者后台「凭证与基础信息」
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# 已部署的 Supabase Edge Function 地址
DINGTALK_AGENT_ENDPOINT=https://YOUR_PROJECT.supabase.co/functions/v1/dingtalk-agent

# 连接器与 Edge Function 共用的高强度随机口令，不要提交到 Git
DINGTALK_CONNECTOR_TOKEN=

# 本地健康检查端口
PORT=8787

# 试点阶段默认关闭主动通知。开启时必须同时填写测试人员 staffId 白名单。
DINGTALK_NOTIFICATIONS_ENABLED=false
DINGTALK_NOTIFICATION_STAFF_ALLOWLIST=
DINGTALK_NOTIFICATION_ALLOW_ALL=false
DINGTALK_NOTIFICATION_POLL_MS=60000

# 模型响应超过 1.5 秒时，先回复「正在分析」
DINGTALK_PROGRESS_REPLY=true
DINGTALK_DEBUG=false
